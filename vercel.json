{
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/wp-admin/(.*)",
            "permanent": true,
            "destination": "https://www.google.com"
        },
        {
            "source": "/wp-login/(.*)",
            "permanent": true,
            "destination": "https://www.google.com"
        },
        {
            "source": "/wp-content/(.*)",
            "permanent": true,
            "destination": "https://www.google.com"
        },
        {
            "source": "/wp-includes/(.*)",
            "permanent": true,
            "destination": "https://www.google.com"
        },
        {
            "source": "/(.*).php",
            "permanent": true,
            "destination": "https://www.google.com"
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        { "source": "/:path", "destination": "/index.html" }
    ]
}